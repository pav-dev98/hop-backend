# Entorno LOCAL (docker-compose). Copia este archivo a `.env`.
# La base local es la del servicio `db` de docker-compose, publicada en el
# host en el puerto 5433 (user/pass: peace/peace, base: peace_houses).
DATABASE_URL=postgresql://peace:peace@localhost:5433/peace_houses
JWT_SECRET_KEY=your-secret-key-min-32-chars
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
PORT=3000
NODE_ENV=development

# Producción (AWS Lambda): NO se configura aquí. La DATABASE_URL apunta a
# Neon (PostgreSQL serverless) con sslmode=require y se define directamente en
# las variables de entorno de la función Lambda. Formato:
#   postgresql://<user>:<password>@<host>.sa-east-1.aws.neon.tech/<db>?sslmode=require
