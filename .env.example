# Entorno LOCAL (docker-compose). Copia este archivo a `.env`.
# Fuente de verdad de las variables de la app y de la base de datos local.
# Producción (Neon) se configura en la Lambda, NO aquí.

# --- Base de datos local (servicio `db` de docker-compose) ---
POSTGRES_USER=peace
POSTGRES_PASSWORD=peace
POSTGRES_DB=peace_houses
# Puerto publicado en el host (interno siempre 5432).
DB_HOST_PORT=5433

# DATABASE_URL para herramientas ejecutadas desde el HOST (Prisma CLI / Studio).
# Dentro de compose la app la sobrescribe para usar el hostname `db`.
DATABASE_URL=postgresql://peace:peace@localhost:5433/peace_houses

# --- App ---
JWT_SECRET_KEY=your-secret-key-min-32-chars
JWT_EXPIRES_IN=24h
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
PORT=3000
NODE_ENV=development
SEED_ON_START=true

# Producción (AWS Lambda): DATABASE_URL apunta a Neon (PostgreSQL serverless)
# con sslmode=require y se define en las variables de entorno de la Lambda:
#   postgresql://<user>:<password>@<host>.sa-east-1.aws.neon.tech/<db>?sslmode=require
